# ════════════════════════════════════════════════════════════════
#  Nova Arsenal — .gitignore
#  Keep the repo lean: source + tests + configs only.
#  All generated artifacts go to ~/nova_workspace (not committed).
# ════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pdm-python
.venv/
venv/
env/
ENV/
.python-version
*.pdb

# ── Node / JS ─────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/cache
.npm/
.node_repl_history
package-lock.json

# ── Nova generated outputs (ALL go to ~/nova_workspace) ──────────
nova_workspace/
~/nova_workspace/
nova_*.json
nova_*.html
nova_*.har
nova_*.png
nova_*.jpg
nova_*.md
nova_trace_*.json
nova_session_*.json
nova_codebase_map_*.json
nova_eval_*.json
nova_diff_*.json
nova_patches.json
nova_detection_rules.json
nova_audit_report.json
nova_tracker_*.json
nova_threat_model.json
nova_daybreak_report.json
nova_sast_report.json
nova_sca_report.json
nova_git_report.json
nova_cicd_report.json
nova_idor_report.json
nova_graphql_report.json
nova_csrf_report.json
nova_business_logic_report.json
nova_llm_injection_report.json
nova_zero_day_report.json
nova_supply_chain_report.json
nova_container_report.json

# ── Screenshots / HAR / Reports ────────────────────────────────────
screenshots/
hars/
reports/
*.har
*.pcap
*.pcapng

# ── Eval fixtures (generated during test runs) ──────────────────
eval_fixtures/

# ── Secrets / Environment ─────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
id_rsa
id_ed25519
*.asc

# ── IDE / OS ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/
*.out

# ── Coverage / test artefacts ─────────────────────────────────────
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
test-results/
junit*.xml

# ── Compiled / build outputs ─────────────────────────────────────
*.o
*.a
*.lib
*.dll
*.exe
*.dylib
target/
out/
.next/
.nuxt/

# ── Docker / cloud state ─────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# ── Virtualenv aliases ────────────────────────────────────────────
.virtualenv
pyenv
pyvenv.cfg
