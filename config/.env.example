# Nova-Arsenal Environment Variables
# Copy to .env and customize

# LLM API Keys (optional - Ollama works without keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Authentication
JWT_SECRET=change-this-to-a-random-secret
NEXTAUTH_SECRET=change-this-to-another-random-secret

# Database
DATABASE_URL=sqlite+aiosqlite:///workspace/nova.db

# Agent Configuration
NOVA_LLM_URL=http://llm:11434
NOVA_LLM_MODEL=
NOVA_WORKSPACE=/workspace
NOVA_MAX_STEPS=40
NOVA_PERMISSION_PROFILE=scoped

# Web UI
NEXTAUTH_URL=http://localhost:3000
AGENT_API_URL=http://agent:8080

# Docker
COMPOSE_PROJECT_NAME=nova-arsenal

# Development
DEBUG=false
LOG_LEVEL=INFO
