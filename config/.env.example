# Nova-Arsenal Environment Variables
# Copy to project root as `.env` (or `config/.env`) and fill in keys you have.
#
# Bring-your-own-key (BYOK): set ANY of the provider keys below. Nova auto-detects
# them and routes the agent/chat through your subscription. No vendor lock-in.
#
# Prefer a provider:
#   export LLM_PROVIDER=openai
#   export LLM_MODEL=gpt-4o
# Or use OpenRouter with one key for many models:
#   export LLM_PROVIDER=openrouter
#   export OPENROUTER_API_KEY=sk-or-...

# ── Cloud LLM API keys (set the ones you subscribe to) ──────────────────────
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_API_KEY=
# GEMINI_API_KEY=          # alias for GOOGLE_API_KEY
# GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/auto

DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

DASHSCOPE_API_KEY=
# QWEN_API_KEY=            # alias
# QWEN_MODEL=qwen-max

HUGGINGFACE_API_KEY=
# HF_TOKEN=                # alias
# HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct

OPCODE_API_KEY=
# OPENCODE_API_KEY=        # alias

# ── Choose primary provider (optional) ─────────────────────────────────────
# openai | anthropic | gemini | openrouter | deepseek | qwen | huggingface | ollama | opencode
LLM_PROVIDER=
LLM_MODEL=
# Aliases also accepted:
# NOVA_LLM_PROVIDER=
# NOVA_LLM_MODEL=

# ── Local Ollama (free, no key) ────────────────────────────────────────────
NOVA_LLM_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1

# ── Authentication (Nova platform users, not LLM keys) ─────────────────────
JWT_SECRET=change-this-to-a-random-secret
NEXTAUTH_SECRET=change-this-to-another-random-secret

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///workspace/nova.db

# ── Agent ──────────────────────────────────────────────────────────────────
NOVA_WORKSPACE=/workspace
NOVA_MAX_STEPS=40
NOVA_PERMISSION_PROFILE=scoped
NOVA_CONFIG=config/settings.yaml

# ── Web UI ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
AGENT_API_URL=http://localhost:8000

# ── Misc ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=nova-arsenal
DEBUG=false
LOG_LEVEL=INFO
