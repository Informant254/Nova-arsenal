# 🦅 Nova Arsenal — Environment Configuration Template
#
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Or set via shell exports:
#   export OPENAI_API_KEY="sk-..."

# ═══════════════════════════════════════════════════════════════
# LLM PROVIDER CASCADE
# Nova tries providers in this order: OpenAI → Anthropic → Gemini → Ollama
# Set whichever you have — Nova auto-selects the first available.
# ═══════════════════════════════════════════════════════════════

# 1st choice: OpenAI GPT-4o (fastest, best quality)
# https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# 2nd choice: Anthropic Claude (strong reasoning)
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# 3rd choice: Google Gemini (free tier available)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# 4th choice: Local Ollama (free, no internet needed)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull qwen3:8b
NOVA_LLM_URL=http://localhost:11434
NOVA_LLM_MODEL=qwen3:8b

# ═══════════════════════════════════════════════════════════════
# TRUTH ENGINE
# ═══════════════════════════════════════════════════════════════

# Minimum confidence to report a finding as real (0.0 – 1.0)
# 0.95 = strictest (only near-certain findings reported) ← RECOMMENDED
# 0.85 = balanced
# 0.75 = looser (more bugs found, some FPs possible)
# 0.70 = aggressive (maximum bug coverage)
NOVA_TRUTH_THRESHOLD=0.95

# Set to "1" to bypass Truth Engine entirely (debug only — NEVER in production)
# NOVA_TRUTH_DISABLED=1

# ═══════════════════════════════════════════════════════════════
# OOB (OUT-OF-BAND) VERIFICATION — Blind Bug Detection
# Detects: blind SSRF, blind XXE, blind SQLi, blind RCE
#
# Nova uses interactsh (free, open source, no account needed).
# Install: go install -v github.com/projectdiscovery/interactsh/cmd/interactsh-client@latest
#
# Leave blank to use ProjectDiscovery's public server (oast.pro).
# Self-hosted: set NOVA_INTERACTSH_SERVER to your server URL.
# ═══════════════════════════════════════════════════════════════
NOVA_INTERACTSH_SERVER=
NOVA_INTERACTSH_TOKEN=

# ═══════════════════════════════════════════════════════════════
# NOTIFICATIONS — Telegram (real-time mobile alerts)
# Nova fires an alert for every confirmed finding.
# ═══════════════════════════════════════════════════════════════

# Step 1: Message @BotFather on Telegram → /newbot → copy token
NOVA_TELEGRAM_TOKEN=

# Step 2: Start your bot → message it → get chat ID from:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
NOVA_TELEGRAM_CHAT_ID=

# Legacy env names also supported:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Discord / Slack webhooks
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════
# RUNTIME CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Default scan target (overridden per command)
NOVA_TARGET=http://localhost:3000

# Where reports, sessions, and logs are saved
NOVA_WORKSPACE=~/nova_workspace

# Max agentic steps per run (prevents runaway loops)
NOVA_MAX_STEPS=40

# Permission profile: read_only | scoped | full
# - read_only : no network/shell (CI/CD safe)
# - scoped    : network limited to NOVA_TARGET (default)
# - full      : all tools enabled (local dev only)
NOVA_PERMISSION_PROFILE=scoped

# Point to cloned target source for Phase 0 codebase mapping
# Leave blank for URL-only scans
NOVA_SOURCE_DIR=

# ═══════════════════════════════════════════════════════════════
# BUG BOUNTY PLATFORM (optional)
# ═══════════════════════════════════════════════════════════════

# HackerOne program handle (used in report generation)
HACKERONE_PROGRAM=

# GitHub Token (for GitHub-hosted target scanning)
GITHUB_TOKEN=

# Your org name (appears in reports)
NOVA_ORG_NAME=Nova Arsenal

# ═══════════════════════════════════════════════════════════════
# ADVANCED / DEBUGGING
# ═══════════════════════════════════════════════════════════════

# Proxy (if behind corporate network)
# NOVA_PROXY=http://proxy.company.com:8080

# Verbose logging
DEBUG=false

# ═══════════════════════════════════════════════════════════════
# QUICK START
# ═══════════════════════════════════════════════════════════════
#
# ── OFFLINE (Ollama only, free) ───────────────────────────────
#   ollama serve && ollama pull qwen3:8b
#   python3 nova.py "Hunt http://localhost:3000"
#
# ── WITH OPENAI ───────────────────────────────────────────────
#   OPENAI_API_KEY=sk-...
#   python3 nova.py "Full stack scan on https://target.com"
#
# ── WITH TELEGRAM ALERTS ──────────────────────────────────────
#   NOVA_TELEGRAM_TOKEN=<your-bot-token>
#   NOVA_TELEGRAM_CHAT_ID=<your-chat-id>
#   python3 nova.py "Hunt https://target.com"
#
# ── WITH BLIND BUG DETECTION (interactsh) ────────────────────
#   go install github.com/projectdiscovery/interactsh/cmd/interactsh-client@latest
#   python3 nova.py "Hunt https://target.com"   ← OOB auto-detected
