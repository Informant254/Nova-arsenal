# 🦅 Nova Arsenal — Environment Configuration Template
#
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Or set via shell exports:
#   export OPENAI_API_KEY="sk-..."

# ═══════════════════════════════════════════════════════════════
# LLM PROVIDER SELECTION
# ═══════════════════════════════════════════════════════════════

# OpenAI (https://platform.openai.com/account/api-keys)
# Leave blank to skip; Nova will try next provider
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/account/keys)
ANTHROPIC_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Local Ollama (free, no API key needed)
# Set to http://localhost:11434 if running locally
NOVA_LLM_URL=http://localhost:11434

# Which Ollama model to use for fast queries
# Options: qwen3:8b (fast), qwen3:30b (best), deepseek-r1:14b (reasoning)
NOVA_LLM_MODEL=qwen3:8b

# ═══════════════════════════════════════════════════════════════
# NOVA RUNTIME CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Default target (can be overridden per command)
NOVA_TARGET=http://localhost:3000

# Workspace directory (where reports, logs, sessions are saved)
NOVA_WORKSPACE=~/nova_workspace

# Max steps per agent run (prevents infinite loops)
NOVA_MAX_STEPS=40

# Permission profile: read_only | scoped | full
# - read_only: No network/shell (CI/CD safe)
# - scoped: Network limited to NOVA_TARGET (DEFAULT)
# - full: All tools enabled (local development only)
NOVA_PERMISSION_PROFILE=scoped

# ═══════════════════════════════════════════════════════════════
# NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (get by sending /start to your bot)
TELEGRAM_CHAT_ID=

# Discord Webhook URL (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=

# Slack Webhook URL (api.slack.com/apps → Incoming Webhooks)
SLACK_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════
# EVALUATION TARGETS
# ═══════════════════════════════════════════════════════════════

# Used by nova_eval.py for live testing
# Leave blank to skip live tests

# OWASP Juice Shop
EVAL_JUICE_SHOP=http://localhost:3000

# DVWA (Damn Vulnerable Web Application)
EVAL_DVWA=http://localhost:4280

# WebGoat
EVAL_WEBGOAT=http://localhost:8080/WebGoat

# ═══════════════════════════════════════════════════════════════
# ADVANCED FEATURES
# ═══════════════════════════════════════════════════════════════

# Enable Nova to modify her own code to improve
# NEVER enable for production; local development only
NOVA_ALLOW_EVOLUTION=false

# GitHub Token (for cloud hunting)
GITHUB_TOKEN=

# Organization name (appears in reports)
NOVA_ORG_NAME=My Organization

# HackerOne program handle (optional, for report generation)
HACKERONE_PROGRAM=

# Proxy (if behind corporate proxy)
# NOVA_PROXY=http://proxy.company.com:8080

# Debug mode (verbose logging)
DEBUG=false

# ═══════════════════════════════════════════════════════════════
# QUICK START GUIDE
# ═══════════════════════════════════════════════════════════════
#
# 1. OFFLINE MODE (no API keys needed):
#    - Leave OPENAI_API_KEY, ANTHROPIC_API_KEY, GOOGLE_API_KEY blank
#    - Make sure Ollama is running: ollama serve
#    - Run: python3 nova.py "Hunt http://localhost:3000"
#
# 2. WITH OPENAI:
#    - Set OPENAI_API_KEY=sk-...
#    - Run: python3 nova.py "Hunt http://target.com"
#
# 3. WITH NOTIFICATIONS:
#    - Set TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID
#    - Run: python3 nova.py "Hunt http://target.com"
#    - Alerts will be sent to Telegram
#
# 4. CLOUD HUNTING (GitHub Actions):
#    - Set GITHUB_TOKEN
#    - Run: nova-cloud hunt http://target.com
#    - Hunt runs on GitHub's free runners 24/7
